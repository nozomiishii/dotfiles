# official docs
# https://ghostty.org/docs/config
#
# playground
# https://ghostty.zerebos.com/
#
# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.

# macOS
# https://zenn.dev/kawarimidoll/articles/5f219b4409424b
macos-icon = xray
macos-option-as-alt = true

# Theme
# Run `ghostty +list-themes` to view a list of themes
#
# Gitlab-Dark
# `/Applications/Ghostty.app/Contents/Resources/ghostty/themes/GitLab Dark`
theme = Gitlab Dark

# Font (default)
font-size = 13
font-family = "UDEV Gothic"
# font-family = "PlemolJP Console NF"

# turn off ligature https://ghostty.org/docs/config/reference#font-feature
font-feature = -calt, -liga, -dlig

# Show "Quit Ghostty?" dialog
confirm-close-surface = false

# New windows/tabs open in the same directory as the current terminal
window-inherit-working-directory = true

# Start Ghostty windows maximized
maximize = true

# Restore window state (size, position, tabs) from the previous session
window-save-state = always

# keybindings
# shift + enter: claude codeのinputを改行
keybind = shift+enter=text:\n
# keybind = super+\=new_split:right
# keybind = super+shift+\=new_split:down

# undo
keybind = super+z=text:\x1f
