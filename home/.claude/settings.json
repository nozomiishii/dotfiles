{
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Bash(*.env*)",
      "Bash(gh pr merge:*)",
      "Bash(gh api repos/*/pulls/*/merge*)"
    ]
  },
  "enabledPlugins": {
    "telegram@claude-plugins-official": true
  },
  "sandbox": {
    "network": {
      "allowedDomains": ["github.com"]
    }
  }
}
