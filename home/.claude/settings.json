{
  "autoMemoryEnabled": false,
  "cleanupPeriodDays": 180,
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(deno:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(xargs:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(biome:*)",
      "Bash(vitest:*)",
      "Bash(jest:*)",
      "Bash(playwright:*)",
      "Bash(nix:*)",
      "Bash(home-manager:*)",
      "Bash(brew:*)",
      "Bash(make:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(open:*)",
      "Bash(code:*)",
      "Bash(cursor:*)",
      "Bash(docker run:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.github.com)",
      "WebFetch(domain:github.blog)",
      "WebFetch(domain:*.npmjs.org)",
      "WebFetch(domain:*.npmjs.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Read(./secrets/**)",
      "Bash(*.env*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh api repos/*/pulls/*/merge*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(launchctl:*)",
      "Bash(diskutil:*)",
      "Bash(op:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)"
    ],
    "defaultMode": "auto"
  },
  "enabledMcpjsonServers": [],
  "hooks": {},
  "worktree": {
    "bgIsolation": "none"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "sentry-mcp@sentry-mcp": true
  },
  "extraKnownMarketplaces": {
    "sentry-mcp": {
      "source": {
        "source": "github",
        "repo": "getsentry/sentry-mcp"
      }
    }
  },
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "*.crates.io",
        "deno.land",
        "cdn.jsdelivr.net",
        "unpkg.com",
        "esm.sh",
        "api.anthropic.com",
        "*.npmjs.com",
        "github.blog",
        "context7.com",
        "*.context7.com",
        "cdn.playwright.dev",
        "playwright.download.prss.microsoft.com",
        "*.cloudflare.com"
      ],
      "allowUnixSockets": [
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock",
        "~/Library/Application Support/cmux/cmux.sock"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "org.chromium.Chromium.MachPortRendezvousServer.*",
        "com.apple.trustd.agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "~/.npm",
        "~/Library/pnpm/store"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws/credentials",
        "~/.gnupg",
        "~/.netrc",
        "~/.config/op"
      ]
    },
    "excludedCommands": [
      "docker:*",
      "docker-compose:*",
      "podman:*",
      "git:*",
      "gh:*",
      "make:*",
      "mint:*"
    ]
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "ultracode": false,
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "model": "claude-opus-4-6[1m]"
}
