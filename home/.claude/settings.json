{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(deno:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(echo:*)",
      "Bash(pbcopy:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(xargs:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(biome:*)",
      "Bash(vitest:*)",
      "Bash(jest:*)",
      "Bash(playwright:*)",
      "Bash(nix:*)",
      "Bash(home-manager:*)",
      "Bash(brew:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(open:*)",
      "Bash(code:*)",
      "Bash(cursor:*)",
      "Bash(docker run:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:github.blog)",
      "WebFetch(domain:*.npmjs.org)",
      "WebFetch(domain:*.npmjs.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Read(./secrets/**)",
      "Bash(*.env*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh api repos/*/pulls/*/merge*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(launchctl:*)",
      "Bash(diskutil:*)",
      "Bash(op:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": ["docker:*", "docker-compose:*", "podman:*", "git:*", "gh:*"],
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.aws/credentials", "~/.gnupg", "~/.config/gh/hosts.yml", "~/.netrc", "~/.config/op"],
      "allowWrite": ["/tmp", "~/.npm", "~/Library/pnpm/store"]
    },
    "network": {
      "allowLocalBinding": true,
      "allowUnixSockets": [
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock",
        "~/Library/Application Support/cmux/cmux.sock"
      ],
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "*.crates.io",
        "deno.land",
        "cdn.jsdelivr.net",
        "unpkg.com",
        "esm.sh",
        "api.anthropic.com",
        "*.npmjs.com",
        "github.blog"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-local-settings.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-op-cli.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"'$(date '+%Y-%m-%d %H:%M:%S %Z')'\"}}'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "enabledPlugins": {},
  "attribution": {
    "pr": "",
    "commit": ""
  },
  "enabledMcpjsonServers": [],
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 90,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
