{
  "name": "dotfiles",
  "version": "1.0.0",
  "description": "Doting Dotfiles",
  "homepage": "https://github.com/nozomiishii/dotfiles#readme",
  "bugs": {
    "url": "https://github.com/nozomiishii/dotfiles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nozomiishii/dotfiles.git"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "main": "install.sh",
  "scripts": {
    "format": "pnpm prettier . --check",
    "format:fix": "pnpm prettier . --write",
    "postinstall": "postinstall",
    "lint": "pnpm markdownlint",
    "lint:fix": "pnpm markdownlint:fix",
    "markdownlint": "npx -y markdownlint-cli2@latest '**/*.md' '#node_modules'",
    "markdownlint:fix": "npx -y markdownlint-cli2-fix@latest '**/*.md' '#node_modules'",
    "prettier": "prettier --ignore-unknown --cache",
    "test": "node --version",
    "test:perf": "bash scripts/test_shell_startup_time.sh"
  },
  "devDependencies": {
    "@nozomiishii/commitlint-config": "1.2.0",
    "@nozomiishii/lefthook-config": "1.2.0",
    "@nozomiishii/markdownlint-cli2-config": "1.2.0",
    "@nozomiishii/postinstall": "1.2.0",
    "@nozomiishii/prettier-config": "1.2.0",
    "lefthook": "2.1.8",
    "markdownlint-cli2": "0.22.1"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "24.16.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.15.0",
      "onFail": "download"
    }
  }
}
